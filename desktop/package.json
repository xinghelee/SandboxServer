{
  "name": "sandboxserver-console-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop wrapper (Electron) for the SandboxServer debug console — a site-specific browser that connects to a device's on-device console.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package:mac": "electron-packager . \"SandboxServer Console\" --platform=darwin --arch=arm64 --out=dist --overwrite --app-bundle-id=com.sandboxserver.console --app-version=0.1.0"
  },
  "dependencies": {
    "bonjour-service": "^1.4.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "@electron/packager": "^18.3.6"
  }
}
